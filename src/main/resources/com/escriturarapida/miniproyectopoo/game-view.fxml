<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="420.0" prefWidth="520.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.escriturarapida.miniproyectopoo.controller.GameController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Escritura Rápida" />

    <HBox alignment="CENTER" spacing="30.0">
        <Label fx:id="levelLabel" text="Nivel: 1" />
        <Label fx:id="timerLabel" text="Tiempo: 20 s" />
    </HBox>

    <Label text="Escribe exactamente el siguiente texto:" />

    <Label fx:id="targetTextLabel" style="-fx-font-size: 18px; -fx-background-color: #f0f0f0; -fx-padding: 15px; -fx-border-color: #cccccc;" text="Texto ejemplo" wrapText="true" />

    <TextField fx:id="inputTextField" alignment="CENTER" onAction="#handleValidate" prefWidth="350.0" promptText="Escribe aquí..." />

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="validateButton" onAction="#handleValidate" text="Validar" />
        <Button fx:id="restartButton" onAction="#handleRestart" text="Reiniciar" />
    </HBox>

    <Label fx:id="messageLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="" />
</VBox>
