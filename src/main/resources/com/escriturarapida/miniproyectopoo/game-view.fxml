<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.escriturarapida.miniproyectopoo.controller.GameController"
      alignment="CENTER"
      spacing="15.0"
      prefWidth="520.0"
      prefHeight="420.0">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Escritura Rápida"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <HBox alignment="CENTER" spacing="30.0">
        <Label fx:id="levelLabel" text="Nivel: 1" />
        <Label fx:id="timerLabel" text="Tiempo: 20 s" />
    </HBox>

    <Label text="Escribe exactamente el siguiente texto:" />

    <Label fx:id="targetTextLabel"
           wrapText="true"
           text="Texto ejemplo"
           style="-fx-font-size: 18px; -fx-background-color: #f0f0f0; -fx-padding: 15px; -fx-border-color: #cccccc;" />

    <TextField fx:id="inputTextField"
               promptText="Escribe aquí..."
               onAction="#handleValidate"
               prefWidth="350.0" />

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="validateButton" text="Validar" onAction="#handleValidate"/>
        <Button fx:id="restartButton" text="Reiniciar" onAction="#handleRestart"/>
    </HBox>

    <Label fx:id="messageLabel"
           text=""
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />
</VBox>