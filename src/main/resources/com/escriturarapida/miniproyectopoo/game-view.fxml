<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="420.0" prefWidth="520.0" spacing="20.0" style="-fx-background-color: F5F5F5; -fx-border-color: #DCDCDC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.escriturarapida.miniproyectopoo.controller.GameController">

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <Label style="-fx-font-size: 30px; -fx-font-weight: bold;" text="Escritura Rápida" textFill="#013d79" />

    <HBox alignment="CENTER" spacing="30.0">
        <Label fx:id="levelLabel" text="Nivel: 1">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
        <Label fx:id="timerLabel" text="Tiempo: 20 s">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Label>
    </HBox>

    <Label text="Escribe exactamente el siguiente texto antes de que acabe el tiempo:">
      <font>
         <Font size="14.0" />
      </font></Label>

    <Label fx:id="targetTextLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="56.0" prefWidth="228.0" style="-fx-font-size: 25; -fx-background-color: #f5f5f5; -fx-padding: 10px; -fx-border-color: black; -fx-border-radius: 5;" text="Texto ejemplo" textAlignment="CENTER" wrapText="true">
      <font>
         <Font name="Arial" size="12.0" />
      </font></Label>

    <TextField fx:id="inputTextField" alignment="CENTER" onAction="#handleValidate" prefWidth="350.0" promptText="Escribe el texto exactamente aquí..." />

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="validateButton" onAction="#handleValidate" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Validar">
         <effect>
            <Glow />
         </effect></Button>
        <Button fx:id="restartButton" onAction="#handleRestart" text="Reiniciar" />
    </HBox>

    <Label fx:id="messageLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="" />
</VBox>
