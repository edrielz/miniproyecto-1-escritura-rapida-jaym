<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="25.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.escriturarapida.miniproyectopoo.controller.GameOverController">
      <Label fx:id="headerLabel" alignment="CENTER" text="JUEGO TERMINADO">
      <font>
         <Font name="System Bold" size="22.0" />
      </font></Label>
      <Label fx:id="reasonLabel" alignment="CENTER" text="reasonLabel">
      <font>
         <Font size="16.0" />
      </font></Label>
   <VBox alignment="CENTER" spacing="8.0">
            <Label fx:id="levelsLabel" text="🏆 Niveles completados:">
            <font>
               <Font size="14.0" />
            </font></Label>
            <Label fx:id="levelLabel" text="📊 Nivel alcanzado:">
            <font>
               <Font size="14.0" />
            </font></Label>
            <Label fx:id="timeLabel" text="⏱ Tiempo restante:">
            <font>
               <Font size="14.0" />
            </font></Label>
   </VBox>
    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="restartButton" onAction="#handleRestart" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Jugar otra vez">
            <effect>
                <Glow />
            </effect></Button>
        <Button fx:id="menuButton" onAction="#handleBackToMenu" text="Volver al Menu" />
    </HBox>

   <padding>
      <Insets top="15.0" />
   </padding>

</VBox>
